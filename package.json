{
  "name": "judica",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend && tsc && mkdir -p dist/public && (cp -r frontend/build/client/. dist/public/ || cp -r frontend/dist/. dist/public/)",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:load": "tsx tests/load/deliberation.load.ts",
    "bench": "tsx tests/load/deliberation.load.ts",
    "bench:light": "CONNECTIONS=10 DURATION=10 tsx tests/load/deliberation.load.ts",
    "bench:models": "tsx scripts/tools/benchmark-models.ts",
    "sbom": "node scripts/tools/generate-sbom.mjs",
    "prepare": "husky",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "deliberation",
    "consensus",
    "llm",
    "council",
    "orchestration",
    "multi-model",
    "openai",
    "anthropic",
    "gemini",
    "rag",
    "fastify"
  ],
  "author": "Yash Awasthi",
  "license": "MIT",
  "packageManager": "npm@10.9.2",
  "description": "A multi-model AI orchestration engine with agentic tools and semantic caching.",
  "_dependencyNotes": {
    "ioredis": "Unified Redis client for all operations: general caching (src/lib/redis.ts), BullMQ queues (src/queue/connection.ts), and rate-limit state (src/middleware/rateLimit.ts)."
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/oauth2": "^8.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@octokit/rest": "^22.0.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.7",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "form-data": "^4.0.1",
    "ioredis": "5.10.1",
    "isolated-vm": "6.1.2",
    "jsonwebtoken": "9.0.3",
    "lru-cache": "11.3.6",
    "mammoth": "1.12.0",
    "opossum": "9.0.0",
    "papaparse": "5.5.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "2.4.5",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "prom-client": "^15.1.3",
    "stripe": "^22.1.1",
    "ws": "^8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@types/autocannon": "7.12.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.7.0",
    "@types/opossum": "8.1.9",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "8.20.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "autocannon": "8.0.0",
    "concurrently": "9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "pino-pretty": "13.1.3",
    "playwright": "1.60.0",
    "prettier": "^3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "wrangler": "^4.90.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "postcss": ">=8.5.10",
    "uuid": ">=11.1.0"
  }
}
